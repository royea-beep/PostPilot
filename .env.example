DATABASE_URL="file:./postpilot.db"
JWT_SECRET="generate-a-random-64-char-string-here"
JWT_REFRESH_SECRET="generate-a-different-64-char-string-here"
ENCRYPTION_KEY="generate-64-hex-chars-for-aes256-key"
# In production set to your deployed URL (no trailing slash). Checkout redirect & webhook success URL use this.
# Example: https://postpilot-app-nine.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Social Media OAuth (fill in for each platform)
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# AI (for caption generation — falls back to templates if empty)
ANTHROPIC_API_KEY=""
ANTHROPIC_CAPTION_MODEL=""
ANTHROPIC_CAPTION_MAX_TOKENS=""

# ftable server-to-server caption API (optional)
POSTPILOT_FTABLE_API_KEY=""

# LemonSqueezy (billing — server-only)
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_PRO_VARIANT_ID=""
LEMONSQUEEZY_AGENCY_VARIANT_ID=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
