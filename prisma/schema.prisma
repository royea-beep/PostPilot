generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Agency/developer accounts
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  businessName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Billing
  plan               String   @default("FREE")
  lsCustomerId       String?  @unique @map("ls_customer_id")
  lsSubscriptionId   String?  @map("ls_subscription_id")
  subscriptionStatus String   @default("INACTIVE") @map("subscription_status")
  currentPeriodEnd   DateTime? @map("current_period_end")
  postsThisMonth     Int      @default(0) @map("posts_this_month")
  billingCycleStart  DateTime @default(now()) @map("billing_cycle_start")

  brands        Brand[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Client brands managed by agency
model Brand {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  logoUrl     String?
  industry    String?
  language    String   @default("en") // en, he
  timezone    String   @default("Asia/Jerusalem")

  // Magic link for client access
  token     String   @unique @default(cuid())
  tokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  socialConnections SocialConnection[]
  styleProfile      StyleProfile?
  styleEvents       StyleEvent[]
  mediaUploads      MediaUpload[]
  posts             Post[]
  postDrafts        PostDraft[]
  auditLogs         AuditLog[]

  @@index([userId])
}

// Connected social media accounts
model SocialConnection {
  id        String @id @default(cuid())
  brandId   String
  brand     Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  platform       String   // instagram, facebook, tiktok
  platformUserId String?  // User-level ID from OAuth
  accountName    String?
  accountAvatar  String?
  accountType    String?  // page, business, creator

  // Encrypted OAuth tokens (user-level)
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  iv                    String?
  authTag               String?
  tokenExpiresAt        DateTime?
  scopes                String?

  // Selected Page/Account for publishing (Meta)
  pageId                     String?  // Facebook Page ID or IG Business Account ID
  pageName                   String?  // Display name of selected page
  pageAccessTokenEncrypted   String?  // Encrypted Page Access Token
  pageTokenIv                String?
  pageTokenAuthTag           String?

  metadata   String?  // JSON: extra platform-specific data
  status     String   @default("PENDING") // ACTIVE, EXPIRED, DISCONNECTED, ERROR
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  posts Post[]

  @@unique([brandId, platform])
  @@index([brandId])
}

// Learned posting style per brand
model StyleProfile {
  id      String @id @default(cuid())
  brandId String @unique
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  // Style DNA
  tone             String? // casual, professional, playful, etc.
  emojiStyle       String? // heavy, moderate, none
  hashtagStyle     String? // many (10+), moderate (3-5), minimal (1-2), none
  captionLength    String? // short (<50), medium (50-150), long (150+)
  favoriteEmojis   String? // JSON array of most-used emojis
  favoriteHashtags String? // JSON array of go-to hashtags
  sampleCaptions   String? // JSON array of past captions for AI context
  postingPatterns  String? // JSON: best times, frequency, etc.

  // Extended style signals
  ctaStyle          String? // none, soft, direct
  languageMix       String? // hebrew_only, english_only, mixed
  preferredOpeners  String? // JSON array of common opening patterns
  preferredClosers  String? // JSON array of common closing patterns

  analyzedPostCount Int      @default(0)
  lastAnalyzedAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Uploaded media files
model MediaUpload {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  filename    String
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  durationSec Float?  // for video
  filePath    String  // URL or identifier
  fileData    String? // base64-encoded file data for serverless
  thumbnailPath String?

  mediaType String  // photo, video
  createdAt DateTime @default(now())

  posts      Post[]
  postDrafts PostDraft[]

  @@index([brandId])
}

// AI-generated draft options
model PostDraft {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  mediaId String
  media   MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  // Generated content
  caption     String
  hashtags    String   // JSON array
  format      String   // story, post, reel
  platforms   String   // JSON array of target platforms
  optionIndex Int      // 1, 2, or 3

  // Selection
  selected       Boolean   @default(false)
  editedCaption  String?   // User's manually edited version of the caption
  chosenAt       DateTime? // When user selected this draft
  createdAt      DateTime  @default(now())

  posts Post[]

  @@index([brandId])
  @@index([mediaId])
}

// Published posts
model Post {
  id        String @id @default(cuid())
  brandId   String
  brand     Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  mediaId   String
  media     MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  draftId   String?
  draft     PostDraft? @relation(fields: [draftId], references: [id])
  connectionId String
  connection   SocialConnection @relation(fields: [connectionId], references: [id])

  // Post details
  caption   String
  hashtags  String   // JSON array
  format    String   // story, post, reel
  platform  String   // instagram, facebook, tiktok

  // Platform response
  platformPostId String?
  platformUrl    String?
  status         String   @default("QUEUED") // QUEUED, PROCESSING, SUCCESS, FAILED
  errorCode      String?  // Normalized error code (e.g. TOKEN_EXPIRED, RATE_LIMITED)
  errorMessage   String?
  rawResponse    String?  // Full API response JSON for debugging
  retryCount     Int      @default(0)

  // Scheduling
  scheduledFor DateTime?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([brandId])
  @@index([connectionId])
}

// Audit trail
model AuditLog {
  id        String  @id @default(cuid())
  brandId   String?
  brand     Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  metadata  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([brandId])
}

// Style learning events — tracks generation inputs/outputs, user choices, edits
model StyleEvent {
  id        String @id @default(cuid())
  brandId   String
  brand     Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  eventType          String  // GENERATION, SELECTION, EDIT, PUBLISH
  contentItemId      String? // mediaId reference
  generatedCaptions  String? // JSON: all 3 generated options
  chosenVariantIndex Int?    // Which option (1-3) the user picked
  chosenCaption      String? // The caption as chosen
  finalCaption       String? // The caption after user edits (if different)
  detectedPatterns   String? // JSON: extracted style signals from this event
  source             String? // ai, manual, template
  createdAt          DateTime @default(now())

  @@index([brandId])
  @@index([eventType])
}

// Client analytics events (batch from flush-queue)
model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  payload   String?  // JSON
  timestamp DateTime
  createdAt DateTime @default(now())

  @@index([type])
  @@index([timestamp])
}
